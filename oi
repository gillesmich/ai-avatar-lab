#!/usr/bin/env python3
"""
Extraction PHRCREGIONNAL2012 depuis sauvegarde_appels_offre.gbk
Usage: python3 extract_PHRCREGIONNAL2012.py > phrc2012.csv
"""
import csv, sys, re

GBK = '/workspace/IB_AAP_BAK/sauvegarde_appels_offre.gbk'
OUT = '/workspace/IB_AAP_BAK/PHRCREGIONNAL2012.csv'

BLOC_OFF = 12969876
BLOC_LEN = 16719

# Colonnes dans l'ordre du schéma (extrait du bloc metadata offset 128153)
# Ajuste si le nombre de colonnes par enregistrement diffère
COLS = [
    'CODE_PROJET',
    'NOM','PRENOM','EMAIL',
    'ACTIF',
    'CIVILITE',
    'ANCIEN_CODE_RAPP2',
    'DATE_ENVOI_LISTE_RAPP1','DATE_ENVOI_LISTE_RAPP2',
    'DATE_ENVOI_POINT_RAPP1','DATE_ENVOI_POINT_RAPP2',
    'DATE_ENVOI_LI_RAPP1','DATE_ENVOI_LI_RAPP2',
    'DATE_ENVOI_LI_LISTE_RAPP1','DATE_ENVOI_LI_LISTE_RAPP2',
    'DATE_RETOUR_LI_RAPP1','DATE_RETOUR_LI_RAPP2',
    'NOTE_LI_RAPP1','NOTE_LI_RAPP2',
    'DATE_ENVOI_LI1_RAPP1','DATE_ENVOI_LI1_RAPP2',
    'DATE_RETOUR_LI1_RAPP1','DATE_RETOUR_LI1_RAPP2',
    'NOTE_LI1_RAPP1','NOTE_LI1_RAPP2',
    'DATE_ENVOI_ITEM_RAPP1','DATE_ENVOI_ITEM_RAPP2',
    'SOUS_NOTE1_LI_RAPP1','SOUS_NOTE1_LI_RAPP2',
    'SOUS_NOTE2_LI_RAPP1','SOUS_NOTE2_LI_RAPP2',
]

def read_fields(bloc):
    """Parse tous les champs XDR du bloc gbak."""
    i = 0
    fields = []
    while i < len(bloc) - 4:
        m = bloc[i]
        # Format A: marker>=0xdd + \x00 + ltot + ldat + data
        if m >= 0xdd and i+1 < len(bloc) and bloc[i+1] == 0x00:
            ltot = bloc[i+2]
            ldat = bloc[i+3]
            if ltot > 0 and ldat <= ltot and i+4+ldat <= len(bloc):
                raw = bloc[i+4:i+4+ldat]
                val = raw.decode('latin-1').strip('\x00 \t\r\n')
                fields.append(('STR', val, i))
                i += 4 + ldat
                continue
            elif ltot == 0:
                fields.append(('NULL', None, i))
                i += 4
                continue
        # Format B: \xfd + non-\x00 + ldat + data  (CODE_PROJET numérique)
        elif m == 0xfd and i+1 < len(bloc) and bloc[i+1] != 0x00:
            ldat = bloc[i+2]
            if 0 < ldat <= 10 and i+3+ldat <= len(bloc):
                raw = bloc[i+3:i+3+ldat]
                val = raw.decode('latin-1').strip('\x00 ')
                # Valide: doit ressembler à un code projet (digits/lettres courts)
                if re.match(r'^[A-Za-z0-9 ]+$', val):
                    fields.append(('CODE', val, i))
                    i += 3 + ldat
                    continue
        i += 1
    return fields

def is_printable(v):
    if v is None: return True
    return all(32 <= ord(c) <= 126 or c in '\xe0\xe9\xe8\xea\xf9\xf4\xfb\xe7\xee\xef\xf6\xfc\xe4\xe2\xeb\xe6\xf2\xf3\xf1\xc0\xc9\xc8' for c in v)

def group_records(fields):
    """
    Regroupe les champs en enregistrements.
    Heuristique: un nouvel enregistrement commence par un CODE_PROJET
    suivi de NOM (STR uppercase 2-20 chars) + PRENOM.
    """
    records = []
    i = 0
    while i < len(fields):
        ftype, fval, foff = fields[i]
        # Détecte début d'enregistrement: CODE suivi STR (NOM)
        if ftype == 'CODE' and i+2 < len(fields):
            nom_t, nom_v, _ = fields[i+1]
            prenom_t, prenom_v, _ = fields[i+2]
            if (nom_t == 'STR' and nom_v and len(nom_v) >= 2
                    and nom_v.replace('-','').replace(' ','').replace("'",'').isalpha()
                    and prenom_t == 'STR' and prenom_v and len(prenom_v) >= 2):
                # Collecte jusqu'au prochain CODE
                rec_fields = [fval]  # CODE_PROJET
                j = i + 1
                while j < len(fields) and not (fields[j][0] == 'CODE' and j > i+1):
                    rec_fields.append(fields[j][1])
                    j += 1
                records.append(rec_fields)
                i = j
                continue
        i += 1
    return records

def main():
    with open(GBK, 'rb') as f:
        f.seek(BLOC_OFF + 3)
        bloc = f.read(BLOC_LEN)

    print(f"[INFO] Bloc lu: {len(bloc)} bytes", file=sys.stderr)

    fields = read_fields(bloc)
    print(f"[INFO] Champs extraits: {len(fields)}", file=sys.stderr)

    # Debug: affiche les 30 premiers
    print("[DEBUG] Premiers champs:", file=sys.stderr)
    for ft, fv, fo in fields[:30]:
        print(f"  off={fo:5d} type={ft} val={repr(fv)}", file=sys.stderr)

    records = group_records(fields)
    print(f"[INFO] Enregistrements détectés: {len(records)}", file=sys.stderr)

    with open(OUT, 'w', newline='', encoding='utf-8-sig') as f:
        w = csv.writer(f)
        # Header
        w.writerow(COLS + ['EXTRA_' + str(k) for k in range(20)])
        for rec in records:
            # Pad/truncate à nb colonnes fixe
            row = rec[:len(COLS)] + [''] * max(0, len(COLS) - len(rec))
            # Colonnes supplémentaires si plus de champs
            if len(rec) > len(COLS):
                row += rec[len(COLS):]
            w.writerow(row)

    print(f"[OK] CSV écrit: {OUT}", file=sys.stderr)
    print(f"[OK] {len(records)} lignes", file=sys.stderr)

    # Affiche les 5 premiers pour vérif
    print("\n[SAMPLE] 5 premiers enregistrements:", file=sys.stderr)
    for rec in records[:5]:
        print(f"  {rec[:6]}", file=sys.stderr)

if __name__ == '__main__':
    main()
