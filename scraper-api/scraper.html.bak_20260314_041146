<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Web Scraper</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:monospace;background:#0f1117;color:#e2e8f0;min-height:100vh;padding:16px}
h1{font-size:18px;color:#7dd3fc;margin-bottom:16px}
h1 span{font-size:11px;color:#475569;margin-left:8px}
.card{background:#1e293b;border:1px solid #334155;border-radius:8px;padding:14px;margin-bottom:12px}
input,select{background:#0f1117;border:1px solid #334155;border-radius:6px;color:#e2e8f0;padding:8px 12px;font-size:13px;font-family:monospace;outline:none;width:100%}
input:focus{border-color:#2563eb}
.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
button{border:none;border-radius:6px;color:#fff;cursor:pointer;font-size:12px;font-weight:600;padding:8px 16px;font-family:monospace;white-space:nowrap}
.btn-blue{background:#2563eb}.btn-green{background:#15803d}.btn-gray{background:#334155}.btn-purple{background:#7c3aed}.btn-amber{background:#b45309}
button:disabled{background:#334155;cursor:not-allowed}
.tabs{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:12px}
.tab{padding:5px 12px;border-radius:20px;border:none;cursor:pointer;font-size:11px;font-weight:600;font-family:monospace;background:#1e293b;color:#94a3b8}
.tab.active{background:#2563eb;color:#fff}
.panel{display:none}.panel.active{display:block}
.small{font-size:11px;color:#64748b}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px}
.stat{background:#0f1117;border-radius:6px;padding:8px;text-align:center}
.stat .val{font-size:18px;font-weight:700;color:#7dd3fc}
.stat .lbl{font-size:10px;color:#64748b}
.list-item{padding:6px 0;border-bottom:1px solid #0f1117;font-size:11px}
.list-item .href{color:#38bdf8;word-break:break-all}
.img-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.img-card{background:#0f1117;border-radius:6px;padding:8px}
.img-card img{width:100%;height:80px;object-fit:cover;border-radius:4px;margin-bottom:4px}
.img-card .alt{font-size:10px;color:#64748b;word-break:break-all}
.scroll{max-height:360px;overflow-y:auto}
pre{font-size:10px;color:#94a3b8;white-space:pre-wrap;word-break:break-all;max-height:340px;overflow-y:auto}
table.data{border-collapse:collapse;font-size:11px;width:100%}
table.data td{padding:4px 8px;border:1px solid #334155}
table.data tr:first-child td{color:#7dd3fc;background:#0f1117}
table.data tr:nth-child(even):not(:first-child) td{background:#1a2332}
.contact-item{padding:5px 8px;background:#0f1117;border-radius:5px;margin-bottom:4px;font-size:12px;display:flex;justify-content:space-between;align-items:center}
.sel-item{background:#0f1117;border-radius:6px;padding:8px;margin-bottom:6px;font-size:11px}
.sel-tag{color:#7dd3fc;margin-bottom:3px}
.sel-html{color:#475569;font-size:10px;word-break:break-all}
.err{background:#7f1d1d;border-radius:7px;padding:10px 14px;font-size:12px;color:#fca5a5;margin-bottom:12px}
.meta-row{display:flex;gap:8px;align-items:flex-start;padding:6px 0;border-bottom:1px solid #0f1117}
.meta-row .lbl{font-size:10px;color:#64748b;min-width:90px}
.meta-row .val{font-size:12px;flex:1}
.copy-btn{background:none;border:none;color:#64748b;cursor:pointer;font-size:12px;padding:0}
.heading-item{padding:5px 0;border-bottom:1px solid #0f1117}
#screenshot img{max-width:100%;border-radius:8px;border:1px solid #334155}
.empty{color:#475569;font-size:12px;text-align:center;padding:40px 0}
.empty .icon{font-size:40px;margin-bottom:12px}
#spinner{text-align:center;padding:40px;color:#7dd3fc;display:none}
#fab{position:fixed;bottom:24px;right:16px;z-index:999;display:none;background:linear-gradient(135deg,#b45309,#d97706);border:none;border-radius:14px;color:#fff;cursor:grab;font-size:13px;font-weight:700;font-family:monospace;padding:12px 18px;box-shadow:0 4px 20px #0008;user-select:none;touch-action:none}
#fab .badge{background:#fff2;border-radius:8px;padding:1px 7px;font-size:10px;margin-left:6px;vertical-align:middle}
#histBar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px}
.hist-chip{background:#1e293b;border:1px solid #334155;border-radius:20px;padding:3px 10px;font-size:10px;color:#94a3b8;cursor:pointer;display:flex;gap:5px;align-items:center}
.hist-chip:hover{border-color:#7dd3fc;color:#7dd3fc}
.hist-chip .x{color:#475569;font-size:11px}
.auto-card{margin-bottom:12px;border-radius:8px;overflow:hidden}
.auto-card.top{border:1px solid #b45309}.auto-card.other{border:1px solid #334155}
.auto-head{padding:8px 12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px}
.auto-card.top .auto-head{background:#78350f}
.auto-card.other .auto-head{background:#1e293b}
.ts-tag{font-size:9px;color:#94a3b8;background:#0f1117;padding:2px 6px;border-radius:10px}
#toast{position:fixed;bottom:80px;right:16px;background:#15803d;color:#fff;border-radius:8px;padding:8px 14px;font-size:12px;font-family:monospace;z-index:1000;display:none;box-shadow:0 2px 12px #0006}
/* Deep */
#deepModal{display:none;position:fixed;inset:0;background:#0009;z-index:200;overflow-y:auto;padding:16px}
#deepBox{background:#1e293b;border:1px solid #0e7490;border-radius:12px;padding:18px;max-width:600px;margin:auto}
#deepBox h2{font-size:14px;color:#7dd3fc;margin-bottom:14px}
.drow{display:flex;gap:8px;align-items:center;margin-bottom:8px;flex-wrap:wrap}
.drow label{font-size:10px;color:#64748b;min-width:90px}
.drow input{flex:1;background:#0f1117;border:1px solid #334155;border-radius:6px;color:#e2e8f0;padding:6px 10px;font-size:12px;font-family:monospace;outline:none}
.drow input:focus{border-color:#0e7490}
.dhint{font-size:9px;color:#475569;padding-left:98px;margin-top:-5px;margin-bottom:4px}
#deepBarWrap{background:#0f1117;border-radius:4px;overflow:hidden;margin-bottom:6px;height:8px}
#deepBar{height:8px;background:#0e7490;border-radius:4px;width:0%;transition:width .3s}
#deepLog{font-size:10px;color:#64748b;max-height:120px;overflow-y:auto;font-family:monospace;background:#0f1117;padding:6px;border-radius:4px;margin-top:6px}
#deepResults{margin-top:12px;max-height:320px;overflow-y:auto}
.ditem{background:#0f1117;border-radius:8px;padding:10px;margin-bottom:8px;display:flex;gap:10px}
.ditem img{width:70px;height:50px;object-fit:cover;border-radius:5px;flex-shrink:0}
.ditem .dinfo{flex:1;min-width:0}
.ditem .dtitle{font-size:12px;color:#e2e8f0;font-weight:600;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ditem .dprice{font-size:12px;color:#4ade80;margin-bottom:2px}
.ditem .ddesc{font-size:10px;color:#64748b;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.ditem .dlink{font-size:10px;color:#38bdf8;word-break:break-all;margin-top:2px}
</style>
</head>
<body>
<h1>&#128375; Web Scraper <span>Flask + Playwright</span></h1>
<div id="histBar"></div>
<div class="card">
  <div class="small" style="margin-bottom:6px">&#9881;&#65039; Backend</div>
  <div class="row">
    <input id="apiBase" value="" style="flex:1;max-width:260px" placeholder="laisser vide = auto">
    <label style="font-size:11px;color:#94a3b8;display:flex;align-items:center;gap:5px;cursor:pointer">
      <input type="checkbox" id="jsWait" checked> Attendre JS
    </label>
    <button class="btn-gray" onclick="ping()">Ping</button>
  </div>
</div>
<div class="row" style="margin-bottom:14px">
  <input id="urlInput" placeholder="https://example.com" style="flex:1" onkeydown="if(event.key==='Enter')scrape()">
  <button class="btn-blue" id="btnScrape" onclick="scrape()">&#128375; Scraper</button>
  <button class="btn-green" id="btnExport" onclick="exportJSON()" style="display:none">&#8595; JSON</button>
</div>
<div id="errBox" class="err" style="display:none"></div>
<div id="spinner"><div style="font-size:28px">&#8987;</div><div style="font-size:12px;margin-top:8px">Playwright en cours...</div></div>
<div class="card" id="selectorCard" style="display:none">
  <div class="small" style="margin-bottom:6px">&#128269; Selecteur CSS</div>
  <div class="row">
    <input id="selectorInput" placeholder=".price, table tr, h2" style="flex:1" onkeydown="if(event.key==='Enter')runSelector()">
    <button class="btn-purple" onclick="runSelector()">Extraire</button>
    <button class="btn-gray" onclick="detectClasses()" id="btnDetect" style="display:none">&#128269; Detecter</button>
    <button class="btn-amber" id="btnAuto" onclick="autoScrape()" style="display:none">&#9889; Auto JSON</button>
    <button style="padding:8px 16px;background:#0e7490;border:none;border-radius:6px;color:#fff;cursor:pointer;font-size:12px;font-weight:600;display:none" id="btnDeep" onclick="showDeepPanel()">&#128279; Deep</button>
  </div>
</div>
<div class="tabs" id="tabs" style="display:none">
  <button class="tab active" onclick="switchTab('resume',this)">Resume</button>
  <button class="tab" onclick="switchTab('screenshot',this)">Screenshot</button>
  <button class="tab" onclick="switchTab('links',this)">Liens</button>
  <button class="tab" onclick="switchTab('images',this)">Images</button>
  <button class="tab" onclick="switchTab('headings',this)">Titres</button>
  <button class="tab" onclick="switchTab('text',this)">Texte</button>
  <button class="tab" onclick="switchTab('tables',this)">Tableaux</button>
  <button class="tab" onclick="switchTab('contacts',this)">Contacts</button>
  <button class="tab" onclick="switchTab('selector',this)" id="tabSelector">Selecteur</button>
  <button class="tab" onclick="switchTab('detect',this)" id="tabDetect">&#128269; Classes</button>
  <button class="tab" onclick="switchTab('auto',this)" id="tabAuto">&#9889; Auto JSON</button>
  <button class="tab" onclick="switchTab('raw',this)">Brut</button>
</div>
<div class="card" id="panels" style="display:none">
  <div id="panel-resume" class="panel active"></div>
  <div id="panel-screenshot" class="panel"></div>
  <div id="panel-links" class="panel"></div>
  <div id="panel-images" class="panel"></div>
  <div id="panel-headings" class="panel"></div>
  <div id="panel-text" class="panel"></div>
  <div id="panel-tables" class="panel"></div>
  <div id="panel-contacts" class="panel"></div>
  <div id="panel-selector" class="panel"></div>
  <div id="panel-detect" class="panel"></div>
  <div id="panel-auto" class="panel"></div>
  <div id="panel-raw" class="panel"></div>
</div>
<div class="empty" id="emptyState">
  <div class="icon">&#127760;</div>
  <div>Lance le backend puis entre une URL</div>
</div>
<button id="fab" onclick="exportBestJSON()">&#9889; Meilleur JSON <span class="badge" id="fabBadge">-</span></button>
<div id="toast"></div>

<!-- DEEP MODAL -->
<div id="deepModal">
  <div id="deepBox">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
      <h2>&#128279; Deep Scrape</h2>
      <button onclick="document.getElementById('deepModal').style.display='none'" style="background:none;border:none;color:#64748b;font-size:22px;cursor:pointer;line-height:1">x</button>
    </div>
    <div class="drow"><label>URL listing</label><input id="ds_url" placeholder="https://site.com/annonces"></div>
    <div class="drow"><label>Sel. items</label><input id="ds_items" placeholder="div.odd / article / li.property"></div>
    <div class="dhint">Selecteur CSS des blocs annonces sur la page listing</div>
    <div class="drow"><label>Sel. lien</label><input id="ds_links" value="a"></div>
    <div class="dhint">Selecteur du lien dans chaque bloc</div>
    <hr style="border-color:#334155;margin:10px 0">
    <div style="font-size:10px;color:#64748b;margin-bottom:8px">Page detail - laisser vide = auto</div>
    <div class="drow"><label>Sel. titre</label><input id="ds_title" placeholder="h1 / .titre"></div>
    <div class="drow"><label>Sel. desc.</label><input id="ds_desc" placeholder=".description"></div>
    <div class="drow"><label>Sel. prix</label><input id="ds_price" placeholder=".price / .loyer"></div>
    <div class="drow"><label>Sel. images</label><input id="ds_imgs" placeholder=".slider img"></div>
    <hr style="border-color:#334155;margin:10px 0">
    <div class="drow">
      <label>Max</label><input id="ds_max" type="number" value="20" style="max-width:60px">
      <label style="min-width:50px">Delai ms</label><input id="ds_delay" type="number" value="1000" style="max-width:70px">
      <label style="min-width:50px">JS wait</label><input id="ds_js" type="number" value="2000" style="max-width:70px">
    </div>
    <div class="drow">
      <label>same_domain</label>
      <input type="checkbox" id="ds_same" checked style="width:auto;flex:none">
      <span style="font-size:10px;color:#64748b">Filtrer hors-domaine</span>
    </div>
    <div class="drow"><label>Sauvegarder</label><input id="ds_outfile" placeholder="/workspace/scraper-api/output.json"></div>
    <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap">
      <button id="btnRunDeep" onclick="runDeepScrape()" style="padding:9px 20px;background:#0e7490;border:none;border-radius:7px;color:#fff;cursor:pointer;font-size:13px;font-weight:700">&#128279; Lancer</button>
      <button id="btnDeepExport" onclick="exportDeepJSON()" style="display:none;padding:9px 16px;background:#15803d;border:none;border-radius:7px;color:#fff;cursor:pointer;font-size:12px">&#8595; JSON</button>
      <button id="btnDeepCSV" onclick="exportDeepCSV()" style="display:none;padding:9px 16px;background:#334155;border:none;border-radius:7px;color:#fff;cursor:pointer;font-size:12px">&#8595; CSV</button>
    </div>
    <div id="deepProgress" style="display:none;margin-top:10px">
      <div id="deepBarWrap"><div id="deepBar"></div></div>
      <div id="deepLog"></div>
    </div>
    <div id="deepResults"></div>
  </div>
</div>

<script>
var G={}, _autoResults=[], _scrapeTs=null, _deepData=null;
var _history=JSON.parse(localStorage.getItem('scraper_hist')||'[]');
function apiBase(){return (document.getElementById('apiBase').value.trim()||window.location.origin);}
function $(i){return document.getElementById(i);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function ts(){return new Date().toISOString().replace('T',' ').slice(0,19);}
function toast(msg,col){col=col||'#15803d';var t=$('toast');t.textContent=msg;t.style.background=col;t.style.display='block';clearTimeout(t._t);t._t=setTimeout(function(){t.style.display='none';},2500);}
function err(msg){$('errBox').textContent='! '+msg;$('errBox').style.display='block';}
function clearErr(){$('errBox').style.display='none';}
function copyText(txt,btn){navigator.clipboard.writeText(txt);var o=btn.textContent;btn.textContent='OK';setTimeout(function(){btn.textContent=o;},1500);}
function switchTab(n,el){document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});el.classList.add('active');$('panel-'+n).classList.add('active');}

function addHistory(url){_history=_history.filter(function(u){return u!==url;});_history.unshift(url);if(_history.length>6)_history=_history.slice(0,6);localStorage.setItem('scraper_hist',JSON.stringify(_history));renderHistory();}
function renderHistory(){$('histBar').innerHTML=_history.map(function(u){return '<div class="hist-chip" onclick="loadHist(''+esc(u)+'')"><span>'+esc(u.replace(/^https?:\/\//,'').slice(0,28))+'</span><span class="x" onclick="removeHist(event,''+esc(u)+'')">x</span></div>';}).join('');}
function loadHist(url){$('urlInput').value=url;}
function removeHist(e,url){e.stopPropagation();_history=_history.filter(function(u){return u!==url;});localStorage.setItem('scraper_hist',JSON.stringify(_history));renderHistory();}
renderHistory();

(function(){
  var fab=$('fab');var sx=0,sy=0,dragging=false,moved=false;
  function dn(e){dragging=true;moved=false;var p=e.touches?e.touches[0]:e;sx=p.clientX-fab.getBoundingClientRect().left;sy=p.clientY-fab.getBoundingClientRect().top;fab.style.transition='none';e.preventDefault();}
  function mv(e){if(!dragging)return;moved=true;var p=e.touches?e.touches[0]:e;var x=Math.max(0,Math.min(window.innerWidth-fab.offsetWidth,p.clientX-sx));var y=Math.max(0,Math.min(window.innerHeight-fab.offsetHeight,p.clientY-sy));fab.style.left=x+'px';fab.style.top=y+'px';fab.style.right='auto';fab.style.bottom='auto';e.preventDefault();}
  function up(){dragging=false;if(moved){fab.onclick=null;setTimeout(function(){fab.onclick=exportBestJSON;},50);}}
  fab.addEventListener('mousedown',dn);fab.addEventListener('touchstart',dn,{passive:false});
  document.addEventListener('mousemove',mv);document.addEventListener('touchmove',mv,{passive:false});
  document.addEventListener('mouseup',up);document.addEventListener('touchend',up);
})();

async function ping(){try{var r=await fetch(apiBase()+'/health');var j=await r.json();alert('OK port '+j.port);}catch(e){alert('Injoignable: '+apiBase());}}

async function scrape(){
  clearErr();
  var url=$('urlInput').value.trim();
  if(!url){err('URL manquante');return;}
  if(!/^https?:\/\//i.test(url))url='https://'+url;
  $('btnScrape').disabled=true;$('spinner').style.display='block';
  $('emptyState').style.display='none';$('tabs').style.display='none';
  $('panels').style.display='none';$('selectorCard').style.display='none';
  $('btnExport').style.display='none';$('fab').style.display='none';_autoResults=[];
  try{
    var res=await fetch(apiBase()+'/scrape',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url:url,js_wait:$('jsWait').checked})});
    var data=await res.json();
    if(data.error){err(data.error);return;}
    G=data;G.url=url;_scrapeTs=ts();addHistory(url);renderAll();
    $('tabs').style.display='flex';$('panels').style.display='block';
    $('selectorCard').style.display='block';$('btnExport').style.display='';
    $('btnDetect').style.display='';$('btnAuto').style.display='';$('btnDeep').style.display='';
    switchTab('resume',document.querySelector('.tab'));
    await autoScrape(true);
  }catch(e){err('Backend injoignable: '+apiBase());}
  finally{$('btnScrape').disabled=false;$('spinner').style.display='none';}
}

async function autoScrape(silent){
  if(!G.rawHtml){if(!silent)alert('Lance un scrape dabord');return;}
  var btn=$('btnAuto');var prev=btn.textContent;btn.textContent='...';btn.disabled=true;
  if(!silent){$('panel-auto').innerHTML='<div style="color:#7dd3fc;padding:20px;text-align:center">Analyse...</div>';switchTab('auto',$('tabAuto'));}
  try{
    var res=await fetch(apiBase()+'/autoscrape',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({html:G.rawHtml,base_url:G.url,min_count:2})});
    if(!res.ok){if(!silent)$('panel-auto').innerHTML='<div class="small">Erreur '+res.status+'</div>';return;}
    var json=await res.json();_autoResults=json.results||[];renderAuto(json);updateFAB();
  }catch(e){if(!silent)$('panel-auto').innerHTML='<div class="small">'+e.message+'</div>';}
  finally{btn.textContent=prev;btn.disabled=false;}
}

function updateFAB(){var fab=$('fab');if(!_autoResults.length){fab.style.display='none';return;}var b=_autoResults[0];$('fabBadge').textContent=b.selector.slice(0,20);fab.style.display='block';}

function exportBestJSON(){
  if(!_autoResults.length){toast('Lance Auto JSON dabord','#b45309');return;}
  var b=_autoResults[0];
  var p={_meta:{url:G.url,selector:b.selector,score:b.avg_score,count:b.count,scraped_at:_scrapeTs,exported_at:ts()},items:b.items};
  var blob=new Blob([JSON.stringify(p,null,2)],{type:'application/json'});
  var a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download='best_'+(G.url||'scrape').replace(/^https?:\/\//,'').replace(/[^a-z0-9]/gi,'_').slice(0,30)+'_'+_scrapeTs.replace(/[\s:]/g,'-')+'.json';
  a.click();toast('Export '+b.count+' items OK');
}

function renderAll(){renderResume();renderScreenshot();renderLinks();renderImages();renderHeadings();renderText();renderTables();renderContacts();renderRaw();}

function renderResume(){
  var d=G;
  $('panel-resume').innerHTML='<div class="meta-row"><span class="lbl">Scraped at</span><span class="val" style="color:#fcd34d">'+_scrapeTs+'</span></div>'
    +'<div class="meta-row"><span class="lbl">URL</span><span class="val" style="color:#38bdf8;word-break:break-all">'+esc(d.url||'')+'</span></div>'
    +'<div class="meta-row"><span class="lbl">Titre</span><span class="val">'+esc(d.title||'')+'</span></div>'
    +'<div class="meta-row"><span class="lbl">Description</span><span class="val">'+esc(d.metaDesc||'-')+'</span></div>'
    +'<div class="stats">'
    +[['Liens',(d.links||[]).length],['Images',(d.images||[]).length],['Titres',(d.headings||[]).length],
      ['Tables',(d.tables||[]).length],['Emails',(d.emails||[]).length],['Tel.',(d.phones||[]).length],
      ['Paragraphes',(d.paragraphs||[]).length],['HTML',Math.round((d.rawHtml||'').length/1024)+'kb']]
      .map(function(x){return '<div class="stat"><div class="val">'+x[1]+'</div><div class="lbl">'+x[0]+'</div></div>';}).join('')
    +'</div>';
}
function renderScreenshot(){$('panel-screenshot').innerHTML=G.screenshot?'<div id="screenshot"><img src="'+G.screenshot+'" alt="ss"></div>':'<div class="small">Pas de screenshot.</div>';}
function renderLinks(){
  var links=G.links||[];
  $('panel-links').innerHTML='<div class="row" style="margin-bottom:8px"><span class="small">'+links.length+' liens</span><button class="btn-green" style="padding:3px 10px" onclick="exportCSV(G.links,'liens')">CSV</button></div>'
    +'<div class="scroll">'+links.map(function(l){return '<div class="list-item"><div>'+esc(l.text||'(vide)')+'</div><div class="href">'+esc(l.href)+'</div></div>';}).join('')+'</div>';
}
function renderImages(){
  var imgs=G.images||[];
  $('panel-images').innerHTML='<div class="row" style="margin-bottom:8px"><span class="small">'+imgs.length+' images</span><button class="btn-green" style="padding:3px 10px" onclick="exportCSV(G.images,'images')">CSV</button></div>'
    +'<div class="scroll img-grid">'+imgs.map(function(img){return '<div class="img-card"><img src="'+esc(img.src)+'" onerror="this.style.display='none'"><div class="alt">'+esc(img.alt||img.src.split('/').pop())+'</div></div>';}).join('')+'</div>';
}
function renderHeadings(){
  var hs=G.headings||[];
  var sz={H1:16,H2:14,H3:13,H4:12,H5:11,H6:10},ind={H1:0,H2:12,H3:22,H4:30,H5:36,H6:40},col={H1:'#7dd3fc',H2:'#93c5fd',H3:'#cbd5e1',H4:'#94a3b8',H5:'#64748b',H6:'#475569'};
  $('panel-headings').innerHTML='<div class="scroll">'+hs.map(function(h){return '<div class="heading-item" style="padding-left:'+(ind[h.level]||0)+'px;font-size:'+(sz[h.level]||11)+'px;color:'+(col[h.level]||'#e2e8f0')+'"><span style="font-size:9px;color:#475569;margin-right:6px">'+h.level+'</span>'+esc(h.text)+'</div>';}).join('')+'</div>';
}
function renderText(){
  var ps=G.paragraphs||[];
  $('panel-text').innerHTML='<div class="scroll">'+ps.map(function(p){return '<div style="padding:7px 0;border-bottom:1px solid #0f1117;font-size:12px;line-height:1.6;color:#cbd5e1">'+esc(p)+'</div>';}).join('')+'</div>';
}
function renderTables(){
  var tbls=G.tables||[];
  if(!tbls.length){$('panel-tables').innerHTML='<div class="small">Aucun tableau.</div>';return;}
  $('panel-tables').innerHTML='<div class="scroll">'+tbls.map(function(tbl){return '<div style="margin-bottom:16px"><div class="small" style="margin-bottom:6px">Tableau '+tbl.index+' ('+tbl.rows.length+' lignes)</div><div style="overflow-x:auto"><table class="data">'+tbl.rows.map(function(row){return '<tr>'+row.map(function(cell){return '<td>'+esc(cell)+'</td>';}).join('')+'</tr>';}).join('')+'</table></div></div>';}).join('')+'</div>';
}
function renderContacts(){
  var emails=G.emails||[],phones=G.phones||[];
  $('panel-contacts').innerHTML='<div style="margin-bottom:14px"><div class="small" style="margin-bottom:6px">Emails ('+emails.length+')</div>'+(emails.length?emails.map(function(e){return '<div class="contact-item" style="color:#38bdf8">'+esc(e)+'</div>';}).join(''):'<div class="small">Aucun.</div>')+'</div>'
    +'<div><div class="small" style="margin-bottom:6px">Tel. ('+phones.length+')</div>'+(phones.length?phones.map(function(p){return '<div class="contact-item" style="color:#a3e635">'+esc(p)+'</div>';}).join(''):'<div class="small">Aucun.</div>')+'</div>';
}
function renderSelector(results,sel){
  $('panel-selector').innerHTML='<div class="small" style="margin-bottom:8px">'+results.length+' element(s) pour '+esc(sel)+'</div><div class="scroll">'+results.map(function(r){return '<div class="sel-item"><div class="sel-tag">&lt;'+r.tag+'&gt;</div><div style="color:#e2e8f0;margin-bottom:3px">'+esc(r.text)+'</div><div class="sel-html">'+esc((r.html||'').slice(0,200))+'</div></div>';}).join('')+'</div>';
}
function renderRaw(){
  var h=G.rawHtml||'';
  $('panel-raw').innerHTML='<div class="row" style="margin-bottom:8px"><span class="small">'+h.length.toLocaleString()+' chars</span><button class="btn-gray" style="padding:3px 10px" onclick="copyText(G.rawHtml,this)">Copier</button></div><pre>'+esc(h.slice(0,30000))+(h.length>30000?'\n...(tronque)':'')+'</pre>';
}
function renderAuto(data){
  var results=data.results||[];
  if(!results.length){$('panel-auto').innerHTML='<div class="small">Aucun selecteur.</div>';return;}
  var html='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px"><span class="small">'+data.total_candidates+' candidats - top '+results.length+' - <span style="color:#fcd34d">'+_scrapeTs+'</span></span><button onclick="exportBestJSON()" style="padding:5px 14px;background:linear-gradient(135deg,#b45309,#d97706);border:none;border-radius:7px;color:#fff;cursor:pointer;font-size:12px;font-weight:700">BEST JSON</button></div>';
  results.forEach(function(r,ri){
    var isTop=ri===0;
    html+='<div class="auto-card '+(isTop?'top':'other')+'"><div class="auto-head"><div style="display:flex;flex-direction:column;gap:3px"><code style="color:'+(isTop?'#fcd34d':'#a78bfa')+';font-size:12px">'+esc(r.selector)+'</code><span class="ts-tag">'+_scrapeTs+'</span></div>'
      +'<div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap"><span style="font-size:10px;color:#94a3b8">'+r.count+' items score '+r.avg_score+'</span>'
      +'<button onclick="injectSelector(''+r.selector.replace(/'/g,"\'")+'')" style="padding:3px 10px;background:#7c3aed;border:none;border-radius:5px;color:#fff;cursor:pointer;font-size:11px">CSS</button>'
      +'<button onclick="downloadAutoJSON('+ri+')" style="padding:3px 10px;background:#15803d;border:none;border-radius:5px;color:#fff;cursor:pointer;font-size:11px">JSON</button>'
      +(isTop?'<button onclick="exportBestJSON()" style="padding:3px 10px;background:linear-gradient(135deg,#b45309,#d97706);border:none;border-radius:5px;color:#fff;cursor:pointer;font-size:11px;font-weight:700">BEST</button>':'')
      +'</div></div>'
      +'<div style="padding:8px;max-height:200px;overflow-y:auto">'+r.items.slice(0,3).map(function(item){return '<div style="background:#0f1117;border-radius:6px;padding:8px;margin-bottom:6px;font-size:11px"><div style="color:#e2e8f0;margin-bottom:3px">'+esc(item.text.slice(0,200))+'</div>'+(item.prices.length?'<div style="color:#4ade80">'+item.prices.join(' ')+'</div>':'')+(item.links.length?'<div style="color:#38bdf8">'+esc(item.links[0].href)+'</div>':'')+'</div>';}).join('')+(r.items.length>3?'<div class="small">+'+( r.items.length-3)+' elements</div>':'')
      +'</div></div>';
  });
  $('panel-auto').innerHTML=html;
}
function renderDetect(candidates){
  if(!candidates.length){$('panel-detect').innerHTML='<div class="small">Aucune classe repetee.</div>';return;}
  $('panel-detect').innerHTML='<div class="small" style="margin-bottom:10px">'+candidates.length+' selecteurs</div><div class="scroll">'+candidates.map(function(c){return '<div onclick="injectSelector(''+c.selector.replace(/'/g,"\'")+'');" style="padding:8px;background:#0f1117;border-radius:6px;margin-bottom:6px;cursor:pointer;border:1px solid #334155"><div style="display:flex;justify-content:space-between;margin-bottom:4px"><code style="color:#a78bfa;font-size:12px">'+esc(c.selector)+'</code><span style="font-size:10px;color:#64748b;background:#1e293b;padding:2px 7px;border-radius:10px">'+c.count+'x</span></div><div style="font-size:10px;color:#475569;word-break:break-all">'+esc((c.sample||'').slice(0,200))+'</div></div>';}).join('')+'</div>';
}
function injectSelector(sel){$('selectorInput').value=sel;$('selectorInput').focus();$('selectorInput').style.borderColor='#a78bfa';setTimeout(function(){$('selectorInput').style.borderColor='';},1000);}
async function detectClasses(){
  if(!G.rawHtml){alert('Lance un scrape dabord');return;}
  var btn=$('btnDetect');btn.textContent='...';btn.disabled=true;
  try{var res=await fetch(apiBase()+'/detect',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({html:G.rawHtml})});var json=await res.json();renderDetect(json.candidates||[]);switchTab('detect',$('tabDetect'));}
  catch(e){alert('Erreur: '+e.message);}
  finally{btn.textContent='Detecter';btn.disabled=false;}
}
async function runSelector(){
  var sel=$('selectorInput').value.trim();if(!sel||!G.rawHtml)return;
  try{var res=await fetch(apiBase()+'/selector',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({html:G.rawHtml,base_url:G.url,selector:sel})});var json=await res.json();renderSelector(json.results||[],sel);switchTab('selector',$('tabSelector'));}catch(e){}
}
function exportJSON(){var c=Object.assign({},G);delete c.rawHtml;delete c.screenshot;c._scraped_at=_scrapeTs;var blob=new Blob([JSON.stringify(c,null,2)],{type:'application/json'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='scrape_'+(_scrapeTs||ts()).replace(/[\s:]/g,'-')+'.json';a.click();}
function exportCSV(rows,name){var csv=rows.map(function(r){return Object.values(r).map(function(v){return '"'+String(v).replace(/"/g,'""')+'"';}).join(',');}).join('\n');var blob=new Blob([csv],{type:'text/csv'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name+'_'+(_scrapeTs||ts()).replace(/[\s:]/g,'-')+'.csv';a.click();}
function downloadAutoJSON(idx){var r=(_autoResults||[])[idx];if(!r)return;var p={_meta:{url:G.url,selector:r.selector,score:r.avg_score,count:r.count,scraped_at:_scrapeTs,exported_at:ts()},items:r.items};var blob=new Blob([JSON.stringify(p,null,2)],{type:'application/json'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='auto_'+r.selector.replace(/[^a-z0-9]/gi,'_')+'_'+(_scrapeTs||ts()).replace(/[\s:]/g,'-')+'.json';a.click();toast('JSON '+r.count+' items OK');}

/* DEEP SCRAPE */
function showDeepPanel(){
  var u=$('urlInput').value.trim();if(u)$('ds_url').value=u;
  if(_autoResults.length)$('ds_items').value=_autoResults[0].selector;
  $('deepModal').style.display='block';
}
function _dlog(msg){var el=$('deepLog');el.innerHTML+=msg+'<br>';el.scrollTop=el.scrollHeight;}
function _de(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

async function runDeepScrape(){
  var btn=$('btnRunDeep');
  var base=apiBase();
  var body={
    url:$('ds_url').value.trim(),
    sel_items:$('ds_items').value.trim(),
    sel_links:$('ds_links').value.trim()||'a',
    sel_title:$('ds_title').value.trim(),
    sel_desc:$('ds_desc').value.trim(),
    sel_price:$('ds_price').value.trim(),
    sel_imgs:$('ds_imgs').value.trim(),
    max_items:parseInt($('ds_max').value)||20,
    delay_ms:parseInt($('ds_delay').value)||1000,
    js_wait:parseInt($('ds_js').value)||2000,
    same_domain:$('ds_same').checked,
    output_file:$('ds_outfile').value.trim()
  };
  if(!body.url){alert('URL manquante');return;}
  btn.disabled=true;btn.textContent='...';
  $('deepProgress').style.display='block';
  $('deepLog').innerHTML='';$('deepBar').style.width='5%';
  $('deepResults').innerHTML='';
  $('btnDeepExport').style.display='none';$('btnDeepCSV').style.display='none';
  _deepData=null;
  _dlog('Listing: '+body.url);
  _dlog('apiBase: '+base);
  _dlog('sel_items: '+body.sel_items);
  var prog=5;
  var tot=(body.max_items*body.delay_ms+body.js_wait*2);
  var pt=setInterval(function(){prog=Math.min(prog+2,85);$('deepBar').style.width=prog+'%';},tot/40);
  try{
    _dlog('POST /deepscrape...');
    var res=await fetch(base+'/deepscrape',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    clearInterval(pt);
    _dlog('HTTP '+res.status);
    var data=await res.json();
    if(data.error){_dlog('ERREUR: '+data.error);return;}
    _deepData=data;
    $('deepBar').style.width='100%';
    _dlog('OK: '+data._meta.total+' annonces - '+data._meta.scraped_at);
    if(data._saved_to)_dlog('Sauvegarde: '+data._saved_to);
    _renderDeep(data.items);
    $('btnDeepExport').style.display='';$('btnDeepCSV').style.display='';
  }catch(e){clearInterval(pt);_dlog('FETCH ERREUR: '+e.message);}
  finally{btn.disabled=false;btn.textContent='Lancer';}
}

function _renderDeep(items){
  var el=$('deepResults');
  if(!items.length){el.innerHTML='<div style="font-size:11px;color:#475569;padding:10px">Aucun resultat.</div>';return;}
  el.innerHTML='<div style="font-size:10px;color:#64748b;margin-bottom:8px">'+items.length+' annonces</div>'
    +items.map(function(item){
      var img=item.images&&item.images.length?item.images[0].src:'';
      return '<div class="ditem">'+(img?'<img src="'+_de(img)+'" onerror="this.style.display='none'">':'')
        +'<div class="dinfo"><div class="dtitle">'+_de(item.title||'(sans titre)')+'</div>'
        +(item.price?'<div class="dprice">'+_de(item.price)+'</div>':'')
        +'<div class="ddesc">'+_de(item.description||'')+'</div>'
        +'<div class="dlink">'+_de(item.url)+'</div>'
        +'</div></div>';
    }).join('');
}
function exportDeepJSON(){if(!_deepData)return;var blob=new Blob([JSON.stringify(_deepData,null,2)],{type:'application/json'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='deep_'+((_deepData._meta.scraped_at)||'').replace(/[\s:]/g,'-')+'.json';a.click();}
function exportDeepCSV(){if(!_deepData||!_deepData.items.length)return;var cols=['url','title','price','description','_scraped_at'];var rows=[cols.join(',')].concat(_deepData.items.map(function(it){return cols.map(function(c){return '"'+String(it[c]||'').replace(/"/g,'""')+'"';}).join(',');})).join('\n');var blob=new Blob([rows],{type:'text/csv'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='deep_'+((_deepData._meta.scraped_at)||'').replace(/[\s:]/g,'-')+'.csv';a.click();}
</script>
</body>
